    <worksheet name='Top Markets by Average Liquidity'>
      <table>
        <view>
          <datasources>
            <datasource caption='neondb' name='federated.1fru71g10gla0g1fmdz2r1aiikqc' />
          </datasources>
          <datasource-dependencies datasource='federated.1fru71g10gla0g1fmdz2r1aiikqc'>
            <column-instance column='[liquidity]' derivation='Avg' name='[avg:liquidity:qk]' pivot='key' type='quantitative' />
            <column caption='Liquidity' datatype='real' name='[liquidity]' role='measure' type='quantitative' />
            <column-instance column='[question]' derivation='None' name='[none:question:nk]' pivot='key' type='nominal' />
            <column caption='Question' datatype='string' name='[question]' role='dimension' type='nominal' />
            <column caption='Spread' datatype='real' name='[spread]' role='measure' type='quantitative' />
            <column-instance column='[liquidity]' derivation='Sum' name='[sum:liquidity:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1fru71g10gla0g1fmdz2r1aiikqc].[none:question:nk]'>
            <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([spread])' function='order' user:ui-marker='order'>
                <groupfilter function='except' user:ui-domain='relevant' user:ui-enumeration='exclusive' user:ui-marker='enumerate'>
                  <groupfilter function='level-members' level='[none:question:nk]' />
                  <groupfilter function='union'>
                    <groupfilter function='member' level='[none:question:nk]' member='&quot; NBA Finals G5: Will SGA score 35+ points against the Pacers?&quot;' />
                    <groupfilter function='member' level='[none:question:nk]' member='&quot; NBA Finals G6: Will Jalen Williams score 25+ points against the Pacers?&quot;' />
                    <groupfilter function='member' level='[none:question:nk]' member='&quot; NBA Finals G6: Will SGA score 35+ points against the Pacers?&quot;' />
                    <groupfilter function='member' level='[none:question:nk]' member='&quot; NBA Finals G7: Will Jalen Williams score 22+ points against the Pacers?&quot;' />
